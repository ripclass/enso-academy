# Supabase
NEXT_PUBLIC_SUPABASE_URL=          # Project URL from Supabase dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Public anon key, safe for the browser
SUPABASE_SERVICE_ROLE_KEY=         # Service role key, server-side only, never expose to client

# OpenRouter — single gateway for Claude chat + OpenAI embeddings (OpenAI-protocol).
# Used because direct Anthropic/OpenAI API billing is not workable from Bangladesh. See ADR 0005.
OPENROUTER_API_KEY=                # Claude (generation, lecturer, grader) + text-embedding-3-small

# OpenAI — only needed later for Whisper ASR (OpenRouter does not proxy audio transcription).
# OPENAI_API_KEY=                  # Deferred to the ASR prompt

# Google Cloud TTS (service account JSON path or inline)
GOOGLE_APPLICATION_CREDENTIALS=    # Path to service account JSON, or inline credentials

# Stripe
STRIPE_SECRET_KEY=                 # Server-side Stripe secret key (use test key until live keys issued)
STRIPE_WEBHOOK_SECRET=             # Signing secret for verifying Stripe webhook events
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # Public Stripe key, safe for the browser

# Resend (transactional email)
RESEND_API_KEY=                    # API key for sending transactional emails

# Sentry (error tracking)
SENTRY_DSN=                        # Sentry Data Source Name for error reporting

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Base URL of the app; change per environment
